# SEC EDGAR requires a contact email in the User-Agent header.
# Copy this file to .env and fill in your details.
# See: https://www.sec.gov/os/accessing-edgar-data
SEC_CONTACT="YourAppName your@email.com"

# Google Gemini API key for the Warren Buffett AI chat feature.
# Get one at: https://aistudio.google.com/app/apikey
# If not set, the chat feature will respond with a fallback message.
GEMINI_API_KEY="your-gemini-api-key-here"
